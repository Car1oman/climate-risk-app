# ─────────────────────────────────────────────
# Frontend (expuestas por Vite al navegador)
# ─────────────────────────────────────────────

# URL del backend Express.
# Desarrollo: http://localhost:3001
# Producción: https://<tu-dominio-backend>.onrender.com  (o tu host)
# REQUERIDO — la app no realizará ping al backend si esta variable no está definida.
VITE_API_URL=http://localhost:3001

# Supabase — cliente frontend (anon/public key, segura de exponer en el navegador)
# REQUERIDO para auth — obtener en Supabase Dashboard › Settings › API
VITE_SUPABASE_URL=https://zksuvfaltctiqjlpdaqk.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inprc3V2ZmFsdGN0aXFqbHBkYXFrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU2Njc5MTYsImV4cCI6MjA5MTI0MzkxNn0.Qqt1cUYU3UpbH4U1hhs8TOyrt86zUkzpU60YLehBvqk

# ─────────────────────────────────────────────
# Backend (solo proceso Node — NO en el navegador)
# ─────────────────────────────────────────────

# Supabase — base de datos + PostGIS + Storage
# REQUERIDO — el servidor no arranca sin estas variables.
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inprc3V2ZmFsdGN0aXFqbHBkYXFrIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NTY2NzkxNiwiZXhwIjoyMDkxMjQzOTE2fQ.R-8BfADNgH9VSCDx2zg8lj1UEpp8wVvNnvXPeXzsmdI
SUPABASE_URL=https://zksuvfaltctiqjlpdaqk.supabase.co

# Google Gemini — generación de reportes TCFD/ESRS
GEMINI_API_KEY=AIzaSyD_FKOW4LY7QzTStdXmOQPM_N_6FbIseN0

# Google Geocoding — búsqueda de direcciones en /api/search
GOOGLE_GEOCODING_KEY=AIzaSyCP5AGbiJfHR63TaUOJSDvm63casb_hQ9E

# Mapbox — búsqueda geográfica alternativa en /api/search
MAPBOX_TOKEN=pk.tu_mapbox_token_aqui

# WeatherAPI — clima actual en /api/climate
WEATHER_API_KEY=3938f0f911474a0ba0c230755260604

# Puerto del servidor Express (default: 3001)
PORT=3001

# ─────────────────────────────────────────────
# Seguridad (Sprint 8 — hardening mínimo)
# ─────────────────────────────────────────────

# Entorno de ejecución. En "production" desactiva stack traces y fuerza auth real.
# Valores: development | production
NODE_ENV=development

# CORS — orígenes permitidos para llamadas cross-origin (separados por coma).
# Desarrollo:  http://localhost:5173,http://localhost:3001
# Producción:  https://tu-app.vercel.app,https://tu-backend.onrender.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# Bypass de autenticación para desarrollo local ÚNICAMENTE.
# NUNCA poner en "true" en producción — el servidor lo ignora si NODE_ENV=production.
# En production, los endpoints protegidos exigen Authorization: Bearer <supabase-jwt>
DEV_AUTH_BYPASS=true

# ─────────────────────────────────────────────
# Cloudflare R2 — almacenamiento de documentos (migración desde Supabase Storage)
# OPCIONAL durante la migración — requeridas solo cuando R2 reemplaza Supabase Storage
# ─────────────────────────────────────────────

# Endpoint S3-compatible de tu bucket R2.
# Formato: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Credenciales R2 (API Token con permisos Object Read & Write sobre el bucket)
# Obtener en: Cloudflare Dashboard › R2 › Manage R2 API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Nombre del bucket R2 (debe existir previamente en Cloudflare)
R2_BUCKET=

# URL pública base del bucket (Custom Domain o URL pública R2)
# Ejemplo: https://docs.tu-dominio.com  o  https://pub-<hash>.r2.dev
R2_PUBLIC_URL=

# ─────────────────────────────────────────────
